@page "/"
@page "/tickets"
@inject HelpdeskApiClient Api
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject Microsoft.Extensions.Localization.IStringLocalizer<Tickets> L

<PageTitle>@L["Title"]</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">@L["Heading"]</MudText>

<MudPaper Class="pa-4 mb-6" Elevation="1">
    <MudText Typo="Typo.subtitle1" GutterBottom="true">@L["Section.Open"]</MudText>
    <MudGrid>
        <MudItem xs="12" md="4">
            <MudTextField @bind-Value="_title" Label="@L["Field.Title"].Value" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudTextField @bind-Value="_description" Label="@L["Field.Description"].Value" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" md="2" Class="d-flex align-center">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="_busy" FullWidth="true">
                @L["Button.Open"]
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudTable Items="_tickets" Hover="true" Loading="_busy" Dense="true" Elevation="1">
    <HeaderContent>
        <MudTh>@L["Column.Id"]</MudTh>
        <MudTh>@L["Column.Title"]</MudTh>
        <MudTh>@L["Column.Status"]</MudTh>
        <MudTh>@L["Column.Requester"]</MudTh>
        <MudTh>@L["Column.Actions"]</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="@L["Column.Id"].Value">@context.Id</MudTd>
        <MudTd DataLabel="@L["Column.Title"].Value">@context.Title</MudTd>
        <MudTd DataLabel="@L["Column.Status"].Value">@context.Status</MudTd>
        <MudTd DataLabel="@L["Column.Requester"].Value">@context.RequesterUserId</MudTd>
        <MudTd DataLabel="@L["Column.Actions"].Value">
            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                       OnClick="@(() => Nav.NavigateTo($"/tickets/{context.Id}"))">
                @L["Button.View"]
            </MudButton>
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                           OnClick="@(() => DeleteAsync(context.Id))" Disabled="_busy" />
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText>@L["Empty.Message"]</MudText>
    </NoRecordsContent>
</MudTable>

@code {
    private IReadOnlyList<TicketDTO> _tickets = [];
    private string _title = string.Empty;
    private string _description = string.Empty;
    private bool _busy;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _busy = true;
        try
        {
            _tickets = await Api.GetTicketsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["Snackbar.LoadFailed", ex.Message], Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DeleteAsync(int id)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            L["Dialog.Delete.Title"],
            L["Dialog.Delete.Message", id],
            yesText: L["Dialog.Delete.Confirm"],
            cancelText: L["Dialog.Cancel"]);
        if (confirmed is not true)
        {
            return;
        }

        _busy = true;
        try
        {
            await Api.DeleteTicketAsync(id);
            Snackbar.Add(L["Snackbar.Deleted"], Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["Snackbar.DeleteFailed", ex.Message], Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_title) || string.IsNullOrWhiteSpace(_description))
        {
            Snackbar.Add(L["Snackbar.TitleDescriptionRequired"], Severity.Warning);
            return;
        }

        _busy = true;
        try
        {
            await Api.CreateTicketAsync(_title, _description, requesterUserId: 1);
            Snackbar.Add(L["Snackbar.Opened"], Severity.Success);
            _title = string.Empty;
            _description = string.Empty;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["Snackbar.OpenFailed", ex.Message], Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }
}
