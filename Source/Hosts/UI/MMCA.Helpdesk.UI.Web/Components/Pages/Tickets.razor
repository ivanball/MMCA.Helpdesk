@page "/"
@page "/tickets"
@inject HelpdeskApiClient Api
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IDialogService DialogService

<PageTitle>Helpdesk Tickets</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Support Tickets</MudText>

<MudPaper Class="pa-4 mb-6" Elevation="1">
    <MudText Typo="Typo.subtitle1" GutterBottom="true">Open a ticket</MudText>
    <MudGrid>
        <MudItem xs="12" md="4">
            <MudTextField @bind-Value="_title" Label="Title" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudTextField @bind-Value="_description" Label="Description" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" md="2" Class="d-flex align-center">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="_busy" FullWidth="true">
                Open
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudTable Items="_tickets" Hover="true" Loading="_busy" Dense="true" Elevation="1">
    <HeaderContent>
        <MudTh>Id</MudTh>
        <MudTh>Title</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Requester</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Id">@context.Id</MudTd>
        <MudTd DataLabel="Title">@context.Title</MudTd>
        <MudTd DataLabel="Status">@context.Status</MudTd>
        <MudTd DataLabel="Requester">@context.RequesterUserId</MudTd>
        <MudTd DataLabel="Actions">
            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                       OnClick="@(() => Nav.NavigateTo($"/tickets/{context.Id}"))">
                View
            </MudButton>
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                           OnClick="@(() => DeleteAsync(context.Id))" Disabled="_busy" />
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText>No tickets yet. Open one above.</MudText>
    </NoRecordsContent>
</MudTable>

@code {
    private IReadOnlyList<TicketDTO> _tickets = [];
    private string _title = string.Empty;
    private string _description = string.Empty;
    private bool _busy;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _busy = true;
        try
        {
            _tickets = await Api.GetTicketsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load tickets: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DeleteAsync(int id)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete ticket",
            $"Delete ticket #{id}? Its comments are deleted too.",
            yesText: "Delete",
            cancelText: "Cancel");
        if (confirmed is not true)
        {
            return;
        }

        _busy = true;
        try
        {
            await Api.DeleteTicketAsync(id);
            Snackbar.Add("Ticket deleted.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_title) || string.IsNullOrWhiteSpace(_description))
        {
            Snackbar.Add("Title and description are required.", Severity.Warning);
            return;
        }

        _busy = true;
        try
        {
            await Api.CreateTicketAsync(_title, _description, requesterUserId: 1);
            Snackbar.Add("Ticket opened.", Severity.Success);
            _title = string.Empty;
            _description = string.Empty;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to open ticket: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }
}
