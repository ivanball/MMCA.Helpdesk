@page "/tickets/{Id:int}"
@inject HelpdeskApiClient Api
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject Microsoft.Extensions.Localization.IStringLocalizer<TicketDetail> L

<PageTitle>@L["Title", Id]</PageTitle>

<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack" Class="mb-4">@L["Button.Back"]</MudButton>
<MudButton StartIcon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="DeleteAsync" Disabled="_busy" Class="mb-4 ml-2">
    @L["Button.Delete"]
</MudButton>

@if (_ticket is null)
{
    <MudText>@L["Loading", Id]</MudText>
}
else
{
    <MudText Typo="Typo.h4" GutterBottom="true">@L["Heading", _ticket.Id]</MudText>

    <MudPaper Class="pa-4 mb-6" Elevation="1">
        <MudText Typo="Typo.subtitle1" GutterBottom="true">@L["Section.Details"]</MudText>
        <MudTextField @bind-Value="_title" Label="@L["Field.Title"].Value" Variant="Variant.Outlined" Class="mb-3" />
        <MudTextField @bind-Value="_description" Label="@L["Field.Description"].Value" Variant="Variant.Outlined" Lines="3" Class="mb-3" />
        <MudText Typo="Typo.body2" Class="mb-3">
            @* Enum display localizes via Status.* keys; the wire/enum value itself stays untranslated. *@
            @L["Detail.Status"] <b>@L[$"Status.{_ticket.Status}"]</b> &nbsp;&middot;&nbsp; @L["Detail.Requester"] <b>@_ticket.RequesterUserId</b>
        </MudText>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveDetailsAsync" Disabled="_busy">
            @L["Button.SaveDetails"]
        </MudButton>
    </MudPaper>

    <MudPaper Class="pa-4 mb-6" Elevation="1">
        <MudText Typo="Typo.subtitle1" GutterBottom="true">@L["Section.Status"]</MudText>
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudSelect T="TicketStatus" @bind-Value="_status" Label="@L["Field.Status"].Value" Variant="Variant.Outlined">
                    @foreach (var status in Enum.GetValues<TicketStatus>())
                    {
                        <MudSelectItem Value="status">@L[$"Status.{status}"]</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="6" Class="d-flex align-center">
                <MudButton Color="Color.Secondary" Variant="Variant.Filled" OnClick="ChangeStatusAsync" Disabled="_busy">
                    @L["Button.ChangeStatus"]
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4 mb-6" Elevation="1">
        <MudText Typo="Typo.subtitle1" GutterBottom="true">@L["Section.AddComment"]</MudText>
        <MudGrid>
            <MudItem xs="12" md="10">
                <MudTextField @bind-Value="_newComment" Label="@L["Field.Comment"].Value" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="2" Class="d-flex align-center">
                <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="AddCommentAsync" Disabled="_busy" FullWidth="true">
                    @L["Button.AddComment"]
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudText Typo="Typo.subtitle1" GutterBottom="true">@L["Section.Comments"]</MudText>
    @if (_ticket.Comments.Count == 0)
    {
        <MudText>@L["Empty.Comments"]</MudText>
    }
    else
    {
        foreach (var comment in _ticket.Comments)
        {
            <MudPaper Class="pa-3 mb-2" Outlined="true">
                @if (_editingCommentId == comment.Id)
                {
                    <MudTextField @bind-Value="_editCommentBody" Variant="Variant.Outlined" Class="mb-2" />
                    <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                               OnClick="@(() => SaveCommentAsync(comment.Id))" Disabled="_busy">
                        @L["Button.SaveComment"]
                    </MudButton>
                    <MudButton Size="Size.Small" OnClick="CancelEdit">@L["Button.CancelEdit"]</MudButton>
                }
                else
                {
                    <div class="d-flex align-center justify-space-between">
                        <div>
                            <MudText>@comment.Body</MudText>
                            <MudText Typo="Typo.caption">@L["Comment.By", comment.AuthorUserId]</MudText>
                        </div>
                        <div>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           OnClick="@(() => BeginEdit(comment))" Disabled="_busy" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => RemoveCommentAsync(comment.Id))" Disabled="_busy" />
                        </div>
                    </div>
                }
            </MudPaper>
        }
    }
}

@code {
    [Parameter] public int Id { get; set; }

    private TicketDTO? _ticket;
    private string _title = string.Empty;
    private string _description = string.Empty;
    private TicketStatus _status;
    private string _newComment = string.Empty;
    private string _editCommentBody = string.Empty;
    private int? _editingCommentId;
    private bool _busy;

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _busy = true;
        try
        {
            _ticket = await Api.GetTicketAsync(Id);
            if (_ticket is not null)
            {
                _title = _ticket.Title;
                _description = _ticket.Description;
                _status = _ticket.Status;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["Snackbar.LoadFailed", ex.Message], Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SaveDetailsAsync()
    {
        if (string.IsNullOrWhiteSpace(_title) || string.IsNullOrWhiteSpace(_description))
        {
            Snackbar.Add(L["Snackbar.TitleDescriptionRequired"], Severity.Warning);
            return;
        }

        _busy = true;
        try
        {
            await Api.UpdateTicketAsync(Id, _title, _description);
            Snackbar.Add(L["Snackbar.Updated"], Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["Snackbar.UpdateFailed", ex.Message], Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ChangeStatusAsync()
    {
        _busy = true;
        try
        {
            await Api.ChangeStatusAsync(Id, _status);
            Snackbar.Add(L["Snackbar.StatusUpdated"], Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["Snackbar.StatusChangeFailed", ex.Message], Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task AddCommentAsync()
    {
        if (string.IsNullOrWhiteSpace(_newComment))
        {
            Snackbar.Add(L["Snackbar.CommentEmpty"], Severity.Warning);
            return;
        }

        _busy = true;
        try
        {
            await Api.AddCommentAsync(Id, _newComment, authorUserId: 1);
            _newComment = string.Empty;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["Snackbar.AddCommentFailed", ex.Message], Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private void BeginEdit(TicketCommentDTO comment)
    {
        _editingCommentId = comment.Id;
        _editCommentBody = comment.Body;
    }

    private void CancelEdit()
    {
        _editingCommentId = null;
        _editCommentBody = string.Empty;
    }

    private async Task SaveCommentAsync(int commentId)
    {
        if (string.IsNullOrWhiteSpace(_editCommentBody))
        {
            Snackbar.Add(L["Snackbar.CommentEmpty"], Severity.Warning);
            return;
        }

        _busy = true;
        try
        {
            await Api.EditCommentAsync(Id, commentId, _editCommentBody);
            _editingCommentId = null;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["Snackbar.EditFailed", ex.Message], Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RemoveCommentAsync(int commentId)
    {
        _busy = true;
        try
        {
            await Api.RemoveCommentAsync(Id, commentId);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["Snackbar.RemoveFailed", ex.Message], Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DeleteAsync()
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            L["Dialog.Delete.Title"],
            L["Dialog.Delete.Message", Id],
            yesText: L["Dialog.Delete.Confirm"],
            cancelText: L["Dialog.Cancel"]);
        if (confirmed is not true)
        {
            return;
        }

        _busy = true;
        try
        {
            await Api.DeleteTicketAsync(Id);
            Snackbar.Add(L["Snackbar.Deleted"], Severity.Success);
            Nav.NavigateTo("/tickets");
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["Snackbar.DeleteFailed", ex.Message], Severity.Error);
            _busy = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("/tickets");
}
