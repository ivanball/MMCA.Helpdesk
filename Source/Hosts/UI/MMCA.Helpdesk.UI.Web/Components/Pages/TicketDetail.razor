@page "/tickets/{Id:int}"
@inject HelpdeskApiClient Api
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IDialogService DialogService

<PageTitle>Ticket @Id</PageTitle>

<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack" Class="mb-4">Back to list</MudButton>
<MudButton StartIcon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="DeleteAsync" Disabled="_busy" Class="mb-4 ml-2">
    Delete ticket
</MudButton>

@if (_ticket is null)
{
    <MudText>Loading ticket #@Id ...</MudText>
}
else
{
    <MudText Typo="Typo.h4" GutterBottom="true">Ticket #@_ticket.Id</MudText>

    <MudPaper Class="pa-4 mb-6" Elevation="1">
        <MudText Typo="Typo.subtitle1" GutterBottom="true">Details</MudText>
        <MudTextField @bind-Value="_title" Label="Title" Variant="Variant.Outlined" Class="mb-3" />
        <MudTextField @bind-Value="_description" Label="Description" Variant="Variant.Outlined" Lines="3" Class="mb-3" />
        <MudText Typo="Typo.body2" Class="mb-3">
            Status: <b>@_ticket.Status</b> &nbsp;&middot;&nbsp; Requester: <b>@_ticket.RequesterUserId</b>
        </MudText>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveDetailsAsync" Disabled="_busy">
            Save details
        </MudButton>
    </MudPaper>

    <MudPaper Class="pa-4 mb-6" Elevation="1">
        <MudText Typo="Typo.subtitle1" GutterBottom="true">Status</MudText>
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudSelect T="TicketStatus" @bind-Value="_status" Label="Status" Variant="Variant.Outlined">
                    @foreach (var status in Enum.GetValues<TicketStatus>())
                    {
                        <MudSelectItem Value="status">@status</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="6" Class="d-flex align-center">
                <MudButton Color="Color.Secondary" Variant="Variant.Filled" OnClick="ChangeStatusAsync" Disabled="_busy">
                    Change status
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4 mb-6" Elevation="1">
        <MudText Typo="Typo.subtitle1" GutterBottom="true">Add a comment</MudText>
        <MudGrid>
            <MudItem xs="12" md="10">
                <MudTextField @bind-Value="_newComment" Label="Comment" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="2" Class="d-flex align-center">
                <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="AddCommentAsync" Disabled="_busy" FullWidth="true">
                    Add
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudText Typo="Typo.subtitle1" GutterBottom="true">Comments</MudText>
    @if (_ticket.Comments.Count == 0)
    {
        <MudText>No comments yet.</MudText>
    }
    else
    {
        foreach (var comment in _ticket.Comments)
        {
            <MudPaper Class="pa-3 mb-2" Outlined="true">
                @if (_editingCommentId == comment.Id)
                {
                    <MudTextField @bind-Value="_editCommentBody" Variant="Variant.Outlined" Class="mb-2" />
                    <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                               OnClick="@(() => SaveCommentAsync(comment.Id))" Disabled="_busy">
                        Save
                    </MudButton>
                    <MudButton Size="Size.Small" OnClick="CancelEdit">Cancel</MudButton>
                }
                else
                {
                    <div class="d-flex align-center justify-space-between">
                        <div>
                            <MudText>@comment.Body</MudText>
                            <MudText Typo="Typo.caption">by user @comment.AuthorUserId</MudText>
                        </div>
                        <div>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           OnClick="@(() => BeginEdit(comment))" Disabled="_busy" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => RemoveCommentAsync(comment.Id))" Disabled="_busy" />
                        </div>
                    </div>
                }
            </MudPaper>
        }
    }
}

@code {
    [Parameter] public int Id { get; set; }

    private TicketDTO? _ticket;
    private string _title = string.Empty;
    private string _description = string.Empty;
    private TicketStatus _status;
    private string _newComment = string.Empty;
    private string _editCommentBody = string.Empty;
    private int? _editingCommentId;
    private bool _busy;

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _busy = true;
        try
        {
            _ticket = await Api.GetTicketAsync(Id);
            if (_ticket is not null)
            {
                _title = _ticket.Title;
                _description = _ticket.Description;
                _status = _ticket.Status;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load ticket: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SaveDetailsAsync()
    {
        if (string.IsNullOrWhiteSpace(_title) || string.IsNullOrWhiteSpace(_description))
        {
            Snackbar.Add("Title and description are required.", Severity.Warning);
            return;
        }

        _busy = true;
        try
        {
            await Api.UpdateTicketAsync(Id, _title, _description);
            Snackbar.Add("Ticket updated.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Update failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ChangeStatusAsync()
    {
        _busy = true;
        try
        {
            await Api.ChangeStatusAsync(Id, _status);
            Snackbar.Add("Status updated.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Status change failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task AddCommentAsync()
    {
        if (string.IsNullOrWhiteSpace(_newComment))
        {
            Snackbar.Add("Comment cannot be empty.", Severity.Warning);
            return;
        }

        _busy = true;
        try
        {
            await Api.AddCommentAsync(Id, _newComment, authorUserId: 1);
            _newComment = string.Empty;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Add comment failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private void BeginEdit(TicketCommentDTO comment)
    {
        _editingCommentId = comment.Id;
        _editCommentBody = comment.Body;
    }

    private void CancelEdit()
    {
        _editingCommentId = null;
        _editCommentBody = string.Empty;
    }

    private async Task SaveCommentAsync(int commentId)
    {
        if (string.IsNullOrWhiteSpace(_editCommentBody))
        {
            Snackbar.Add("Comment cannot be empty.", Severity.Warning);
            return;
        }

        _busy = true;
        try
        {
            await Api.EditCommentAsync(Id, commentId, _editCommentBody);
            _editingCommentId = null;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Edit failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RemoveCommentAsync(int commentId)
    {
        _busy = true;
        try
        {
            await Api.RemoveCommentAsync(Id, commentId);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Remove failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DeleteAsync()
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete ticket",
            $"Delete ticket #{Id}? Its comments are deleted too.",
            yesText: "Delete",
            cancelText: "Cancel");
        if (confirmed is not true)
        {
            return;
        }

        _busy = true;
        try
        {
            await Api.DeleteTicketAsync(Id);
            Snackbar.Add("Ticket deleted.", Severity.Success);
            Nav.NavigateTo("/tickets");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error);
            _busy = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("/tickets");
}
