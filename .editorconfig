###############################################################################
# Test files — relaxed rules for test projects
###############################################################################
[Tests/**/*.cs]

# Naming: test methods use underscores and descriptive names
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.S100.severity = none
dotnet_diagnostic.S101.severity = none

# Complexity: test methods can be longer and more complex
dotnet_diagnostic.S107.severity = none
dotnet_diagnostic.S109.severity = none
dotnet_diagnostic.S134.severity = none
dotnet_diagnostic.S1200.severity = none
dotnet_diagnostic.S1541.severity = none
dotnet_diagnostic.MA0051.severity = none

# Test classes are instantiated by test framework
dotnet_diagnostic.CA1812.severity = none

# Test setup may use broader exception handling
dotnet_diagnostic.CA1031.severity = none
dotnet_diagnostic.S2139.severity = none
dotnet_diagnostic.S2221.severity = none

# Magic numbers are normal in test assertions
dotnet_diagnostic.CA1805.severity = none

# Test helper methods don't need to be static
dotnet_diagnostic.S2325.severity = none
dotnet_diagnostic.CA1822.severity = none

# Allow NotImplementedException in test doubles
dotnet_diagnostic.MA0025.severity = none

# Allow flexible string comparisons in test assertions
dotnet_diagnostic.MA0001.severity = none
dotnet_diagnostic.MA0006.severity = none

###############################################################################
# Razor/Blazor files
###############################################################################
[*.razor]
indent_size = 4

[*.cshtml]
indent_size = 4
