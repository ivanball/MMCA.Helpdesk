<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    The scaffold defaults to local-source mode (local.props => UseLocalMMCA=true), so the MMCA.Common.*
    packages resolve from ..\MMCA.Common\Source via ProjectReference and are NOT fetched from a feed.
    Everything else comes from nuget.org.

    To consume MMCA.Common as published NuGet packages instead (delete local.props), add the GitHub
    Packages feed and a packageSourceMapping for MMCA.* (see GETTING-STARTED.md, Phase 1):

      <add key="github-mmca" value="https://nuget.pkg.github.com/<org>/index.json" />
      ... with packageSourceMapping MMCA.* -> github-mmca and a %GITHUB_TOKEN% credential.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
